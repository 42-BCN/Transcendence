{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./",
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "@contracts/*": ["src/contracts/api/*"],
      "@shared": ["src/shared/index.ts"],
      "@shared/*": ["src/shared/*"],
      "@/*": ["src/*"]
    },

    "strict": true,
    "noUncheckedIndexedAccess": true,

    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "scripts/users.bootstrap.ts",
    "scripts/bootstrap.ts",
    "scripts/users.seed.ts"
  ]
}
