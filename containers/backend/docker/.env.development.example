# -----------------------------
# Database
# -----------------------------
PGUSER=app
PGPASSWORD=change-me
PGHOST=postgres
PGDATABASE=app

# -----------------------------
# Sessions (connect-redis; compose sets REDIS_URL by default)
# -----------------------------
SESSION_SECRET=change-me
SESSION_TTL=604800000
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------
# Friendships → socket server (setup-env.sh sets defaults; compose may override)
# -----------------------------
SOCKET_SERVICE_URL=https://socket:3100
# Optional: if set on backend and socket, internal routes require x-internal-secret
SOCKET_INTERNAL_SECRET=change-me

# -----------------------------
# App
# -----------------------------
NODE_ENV=development
APP_BASE_URL=https://localhost:8443
# -----------------------------
# Google oauth
# -----------------------------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://localhost:8443/api/auth/callback/google
GMAIL_REFRESH_TOKEN=YOUR_GMAIL_REFRESH_TOKEN
GMAIL_SENDER_EMAIL=YOUR_GMAIL_SENDER_EMAIL
GMAIL_SENDER_NAME=YOUR_GMAIL_SENDER_NAME
