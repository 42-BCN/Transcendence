{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier . --write",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "node --import=dotenv/config ./node_modules/prisma/build/index.js generate",
    "prisma:db:pull": "node --import=dotenv/config ./node_modules/prisma/build/index.js db pull",
    "prisma:db:push": "node --import=dotenv/config ./node_modules/prisma/build/index.js db push",
    "db:reset": "node --import=dotenv/config ./node_modules/prisma/build/index.js db push --force-reset",
    "db:seed": "node --import=dotenv/config ./node_modules/prisma/build/index.js db seed",
    "smoke:friendships": "node scripts/smoke-friendships.mjs"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "connect-redis": "^9.0.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.2.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unicorn": "^56.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
