{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "@contracts/*": [
        "src/contracts/api/*",
        "src/contracts/*",
        "../../contracts/api/*",
        "../../contracts/*"
      ],
      "@shared": ["src/shared/index.ts"],
      "@shared/*": ["src/shared/*"],
      "@/*": ["src/*"],
      "@lib/*": ["src/lib/*"],
      "@auth/*": ["src/auth/*"]
    },

    "strict": true,
    "noUncheckedIndexedAccess": true,

    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
